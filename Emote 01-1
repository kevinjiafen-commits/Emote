local modButtons = {}
local function createModToggle(text, offColor, onColor, parent, callback)
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = offColor
    btn.Text = text .. ": OFF"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 8 
    btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 3)

    local state = false
    local function updateState(newState)
        state = newState
        callback(state)
        btn.Text = text .. (state and ": ON" or ": OFF")
        btn.BackgroundColor3 = state and onColor or offColor
    end
    btn.MouseButton1Click:Connect(function() updateState(not state) end)
    table.insert(modButtons, {reset = function() updateState(false) end})
end

