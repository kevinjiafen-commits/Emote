-- Emote 邏輯
local allowedBodyParts = {
    ["Head"]=true, ["Torso"]=true, ["UpperTorso"]=true, ["LowerTorso"]=true,
    ["Left Arm"]=true, ["Right Arm"]=true, ["Left Leg"]=true, ["Right Leg"]=true,
    ["LeftUpperArm"]=true, ["LeftLowerArm"]=true, ["LeftHand"]=true,
    ["RightUpperArm"]=true, ["RightLowerArm"]=true, ["RightHand"]=true,
    ["LeftUpperLeg"]=true, ["LeftLowerLeg"]=true, ["LeftFoot"]=true,
    ["RightUpperLeg"]=true, ["RightLowerLeg"]=true, ["RightFoot"]=true
}

local function isValidPart(part)
    if not part:IsA("BasePart") then return false end
    if allowedBodyParts[part.Name] then return true end
    if part.Parent and part.Parent:IsA("Accessory") and part.Name == "Handle" then return true end
    return false
end

local function getCharacterParts(character)
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    local partsInfo = { RootPart = rootPart, Pieces = {} }
    character.Archivable = true
    
    for _, child in ipairs(character:GetDescendants()) do
        if isValidPart(child) then
            child.Archivable = true
            local fakePart = child:Clone()
            for _, subChild in ipairs(fakePart:GetDescendants()) do
                if subChild:IsA("JointInstance") or subChild:IsA("Script") or subChild:IsA("LocalScript") or subChild:IsA("Constraint") or subChild:IsA("BodyMover") or subChild:IsA("Attachment") then
                    subChild:Destroy()
                end
            end
            fakePart.Name = "EmoteVisual_" .. child.Name
            fakePart.Anchored = true
            fakePart.CanCollide = false
            fakePart.CanQuery = false 
            fakePart.Massless = true
            fakePart.CastShadow = false
            fakePart.Parent = fakePartsFolder
            
            fakePart.Material = isNeonGlitchMode and Enum.Material.Neon or (customMatList[currentMatIndex].mat or fakePart.Material)

            local a0 = Instance.new("Attachment", fakePart)
            a0.Position = Vector3.new(0, fakePart.Size.Y/2, 0)
            local a1 = Instance.new("Attachment", fakePart)
            a1.Position = Vector3.new(0, -fakePart.Size.Y/2, 0)
            
            local trail = Instance.new("Trail", fakePart)
            trail.Attachment0 = a0
            trail.Attachment1 = a1
            trail.Enabled = isTrailsMode
            trail.Lifetime = 0.4
            trail.LightEmission = 0.8
            trail.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(1,1)})
            trail.Color = ColorSequence.new(fakePart.Color)
            
            local emitter = Instance.new("ParticleEmitter", fakePart)
            emitter.Enabled = isGhostMode or isNeonGlitchMode
            emitter.Rate = 15
            emitter.Speed = NumberRange.new(1, 3)
            emitter.Lifetime = NumberRange.new(0.5, 1)
            emitter.Size = NumberSequence.new({NumberSequenceKeypoint.new(0,0.5), NumberSequenceKeypoint.new(1,0)})
            emitter.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0,0.5), NumberSequenceKeypoint.new(1,1)})
            
            table.insert(partsInfo.Pieces, {
                realPart = child,
                fakePart = fakePart,
                trail = trail,
                emitter = emitter,
                physicsSeed = chaoticSeed + #partsInfo.Pieces * 13, 
                spinAxis = Vector3.new(math.random(-100,100), math.random(-100,100), math.random(-100,100)).Unit,
                originalMaterial = child.Material,
                originalColor = fakePart.Color
            })
        end
    end
    return partsInfo
end

function playCustomEmote(baseSpeed, style)
    if not targetPlayer.Character then return end
    if not isCustomEmoteActive then
        fakePartsFolder:ClearAllChildren()
        characterParts = getCharacterParts(targetPlayer.Character)
        if not characterParts then return end
        isCustomEmoteActive = true
    end
    currentRotationSpeed = baseSpeed
    currentEmoteStyle = style
    rotationAngle = 0
    chaoticSeed = tick() 
end

function stopCustomEmote()
    isCustomEmoteActive = false
    currentRotationSpeed = 0
    if characterParts then
        for _, info in ipairs(characterParts.Pieces) do
            if info.realPart and info.realPart.Parent then info.realPart.LocalTransparencyModifier = 0 end
        end
        characterParts = nil
    end
    fakePartsFolder:ClearAllChildren()
    workspace.CurrentCamera.FieldOfView = 70
end

local renderConnection
if renderConnection then renderConnection:Disconnect() end

renderConnection = RunService.RenderStepped:Connect(function(dt)
    if not isCustomEmoteActive or not characterParts then return end
    if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        stopCustomEmote()
        return
    end
    
    local speedMultiplier = defaultSpeedFactor
    local actualSpeed = currentRotationSpeed * speedMultiplier
    rotationAngle = rotationAngle + (actualSpeed * dt)
    perlinOffset = perlinOffset + (dt * 0.5) 
    
    local rootCFrame = characterParts.RootPart.CFrame 
    local numPieces = #characterParts.Pieces
    local timeElapsed = tick() * (1 + (speedMultiplier / 100)) 
    
    for i, info in ipairs(characterParts.Pieces) do
        if info.realPart and info.realPart.Parent then info.realPart.LocalTransparencyModifier = 1 end
        if not info.fakePart or not info.fakePart.Parent then continue end

        local angleRad = math.rad(rotationAngle)
        local pieceSeed = info.physicsSeed
        local finalPosition = Vector3.new(0,0,0)
        local currentSize = info.realPart.Size
        local targetTransparency = 0
        local audioRadiusMult = 1 
        
        if isRainbowMode then
            local hue = (timeElapsed * 0.3 + (i / numPieces)) % 1
            info.fakePart.Color = Color3.fromHSV(hue, 1, 1)
            info.trail.Color = ColorSequence.new(info.fakePart.Color)
            info.emitter.Color = ColorSequence.new(info.fakePart.Color)
        elseif isNeonGlitchMode then
            local r = math.noise(timeElapsed * 20, pieceSeed, 0) + 0.5
            local g = math.noise(0, timeElapsed * 25, pieceSeed) + 0.5
            local b = math.noise(pieceSeed, 0, timeElapsed * 18) + 0.5
            if math.random() > 0.4 then
                info.fakePart.Color = Color3.new(math.clamp(r, 0, 1), math.clamp(g, 0, 1), math.clamp(b, 0, 1))
            else
                info.fakePart.Color = math.random() > 0.5 and Color3.new(0, 0, 0) or Color3.new(1, 1, 1)
            end
            info.trail.Color = ColorSequence.new(info.fakePart.Color)
        end
        
        if currentEmoteStyle == "Head Centric Orbit" then
            if info.realPart.Name == "Head" then finalPosition = Vector3.new(0, 1.5, 0)
            else
                local radius = (2.5 + math.noise(pieceSeed, 0, 0) * 1.5) * audioRadiusMult
                local theta = angleRad * 1.5 + ((i / numPieces) * math.pi * 2)
                local yOffset = 1.5 + math.sin(timeElapsed * 4 + pieceSeed) * 1.5
                finalPosition = Vector3.new(math.cos(theta) * radius, yOffset, math.sin(theta) * radius)
            end
        elseif currentEmoteStyle == "Glitched Chaos" then
            if info.realPart.Name == "Head" then finalPosition = Vector3.new(0, 1.5, 0)
            else
                local t = timeElapsed * (1.5 + (pieceSeed % 3))
                local radius = (4.5 + math.noise(pieceSeed, perlinOffset * 0.5, 0) * 2) * audioRadiusMult
                local phi = (t * 0.7) + math.noise(perlinOffset, 0, pieceSeed) * math.pi
                finalPosition = Vector3.new(radius * math.sin(phi) * math.cos(t), 1.5 + (radius * math.cos(phi)), radius * math.sin(phi) * math.sin(t))
            end
        elseif currentEmoteStyle == "Black Hole" then
            local t = ((timeElapsed - chaoticSeed) % 10) / 10
            local radius = 8 * (1 - t^2) * audioRadiusMult
            if t > 0.9 then radius = radius * math.random(50, 200)/100 end 
            local chaoticAngle = angleRad + math.rad((i / numPieces) * 360) + (t * 100)
            finalPosition = Vector3.new(math.cos(chaoticAngle) * radius, math.sin(pieceSeed * t) * (1 - t) * 4, math.sin(chaoticAngle) * radius)
        elseif currentEmoteStyle == "Hyperspace Drift" then
            finalPosition = (info.spinAxis * (3 + math.abs(math.sin(timeElapsed * 1.5 + pieceSeed)) * 7) + Vector3.new(math.sin(timeElapsed * 0.5 + pieceSeed) * 2, math.cos(timeElapsed * 0.7 + pieceSeed * 2) * 2, math.sin(timeElapsed * 0.3 + pieceSeed * 3) * 2)) * audioRadiusMult
        elseif currentEmoteStyle == "Quantum Scatter" then
            finalPosition = (Vector3.new(math.sin(timeElapsed * 2.31 + pieceSeed) * 8, math.cos(timeElapsed * 1.73 + pieceSeed * 1.5) * 6, math.sin(timeElapsed * 3.17 + pieceSeed * 0.8) * 8) + (Vector3.new(math.random(-10,10), math.random(-10,10), math.random(-10,10)) / (100 / defaultSpeedFactor))) * audioRadiusMult
        elseif currentEmoteStyle == "Explosive Tornado" then
            local t = ((timeElapsed * 1.5 + (pieceSeed % 5)) % 5) / 5 
            local chaoticRadius = ((t * 6) + math.noise(pieceSeed, timeElapsed, 0) * 2) * audioRadiusMult
            if t > 0.85 then chaoticRadius = chaoticRadius + ((t - 0.85) * 80 * (math.random(80, 120)/100)) end
            finalPosition = Vector3.new(math.cos(angleRad * 2 + (pieceSeed * 5)) * chaoticRadius, (t * 18) - 5, math.sin(angleRad * 2 + (pieceSeed * 5)) * chaoticRadius)
        elseif currentEmoteStyle == "Dimensional Fracture" then
            local freq = timeElapsed * 8
            if math.random(1, 100) > 85 then finalPosition = Vector3.new(math.random(-25,25), math.random(-10,30), math.random(-25,25))
            else finalPosition = Vector3.new(math.noise(pieceSeed, freq, 0), math.noise(0, pieceSeed, freq), math.noise(freq, 0, pieceSeed)) * (12 + math.random(-8, 8)) end
            finalPosition = finalPosition * audioRadiusMult
        elseif currentEmoteStyle == "Brownian Swarm" then
            local t = timeElapsed * (2 + (pieceSeed % 7))
            local chaosX = math.clamp(math.sin(t * 3.1) * math.cos(t * 2.7) * math.tan(math.sin(t * 0.5)), -1.5, 1.5)
            local chaosY = math.clamp(math.cos(t * 4.2) * math.sin(t * 1.3) * math.tan(math.cos(t * 0.8)), -1.5, 1.5)
            local chaosZ = math.clamp(math.sin(t * 2.9) * math.cos(t * 5.1) * math.tan(math.sin(t * 1.1)), -1.5, 1.5)
            finalPosition = Vector3.new(chaosX, chaosY, chaosZ) * (15 + math.random(0, 15)) * audioRadiusMult
            if math.random() > 0.85 then finalPosition = finalPosition * -1 end
        elseif currentEmoteStyle == "Void Eruption" then
            local burstNoise = math.noise(pieceSeed, timeElapsed * 2.5, 0)
            local radius = (burstNoise > 0.25 and math.random(20, 50) or (burstNoise < -0.3 and math.random(0, 4) or 3)) * audioRadiusMult
            local angle1, angle2 = math.noise(0, pieceSeed, timeElapsed * 4) * math.pi * 2, math.noise(timeElapsed * 4, 0, pieceSeed) * math.pi * 2
            finalPosition = Vector3.new(radius * math.sin(angle1) * math.cos(angle2), radius * math.sin(angle1) * math.sin(angle2), radius * math.cos(angle1)) + (Vector3.new(math.random(-100,100), math.random(-100,100), math.random(-100,100)) / (5000/defaultSpeedFactor))
        elseif currentEmoteStyle == "Neural Glitch" then
            local steppedTime = math.floor(timeElapsed * (15 + (pieceSeed % 15)))
            local gX, gY, gZ = math.noise(steppedTime, pieceSeed, 1) * 25, math.noise(1, steppedTime, pieceSeed) * 25, math.noise(pieceSeed, 1, steppedTime) * 25
            if math.noise(steppedTime * 0.5, pieceSeed, 0) > 0.6 then gX, gY, gZ = gX * 0.1, gY * 0.1, gZ * 0.1 end
            finalPosition = Vector3.new(gX, gY, gZ) * audioRadiusMult
        elseif currentEmoteStyle == "Plasma Orbit" then
            local chaoticT = timeElapsed * (1.5 + (pieceSeed % 4))
            local orbitRadius = (12 + math.sin(chaoticT * 2 + pieceSeed) * 8) * audioRadiusMult
            local theta, phi = chaoticT * math.pi + math.noise(pieceSeed, chaoticT * 0.8, 0) * 10, chaoticT * 1.5 + math.noise(0, pieceSeed, chaoticT * 0.8) * 10
            finalPosition = Vector3.new(orbitRadius * math.sin(phi) * math.cos(theta), orbitRadius * math.sin(phi) * math.sin(theta), orbitRadius * math.cos(phi))
            if math.random(1, 100) > 92 then finalPosition = finalPosition * -1 end
        elseif currentEmoteStyle == "Omniversal Singularity" then
            local cycle = (timeElapsed * 1.5) % math.pi
            local pulse = math.abs(math.sin(cycle ^ 2)) 
            local radius = (2 + (pulse * 30)) * audioRadiusMult
            local theta = pieceSeed + timeElapsed * 10
            local phi = pieceSeed * 2 + timeElapsed * 15
            finalPosition = Vector3.new(radius * math.sin(phi) * math.cos(theta), radius * math.sin(phi) * math.sin(theta), radius * math.cos(phi))
            finalPosition = finalPosition + (info.spinAxis * (math.sin(timeElapsed * 20) * 5))
        elseif currentEmoteStyle == "Reality Disintegration" then
            local step = math.floor(timeElapsed * 20)
            local glitchX = (math.noise(step, pieceSeed, 0) > 0) and 15 or -15
            local glitchY = (math.noise(0, step, pieceSeed) > 0) and 15 or -15
            local glitchZ = (math.noise(pieceSeed, 0, step) > 0) and 15 or -15
            local coreRadius = 5 * audioRadiusMult
            if math.random() > 0.8 then finalPosition = Vector3.new(glitchX, glitchY, glitchZ) * math.random(1, 3) * audioRadiusMult
            else finalPosition = Vector3.new(math.sin(timeElapsed * 2 + pieceSeed) * coreRadius, math.cos(timeElapsed * 2.6 + pieceSeed) * coreRadius, math.tan(math.sin(timeElapsed * 2 + pieceSeed)) * coreRadius) end
        elseif currentEmoteStyle == "DNA Helix" then
            local yOffset = ((i / numPieces) * 15) - 7.5 + math.sin(timeElapsed * 3) * 1.5
            local angle = angleRad * 0.5 + (i * math.pi / (numPieces / 4))
            local radius = 3.5 * audioRadiusMult
            finalPosition = Vector3.new(math.cos(angle) * radius, yOffset, math.sin(angle) * radius)
        elseif currentEmoteStyle == "Pulsing Sphere" then
            local goldenRatio = (1 + math.sqrt(5)) / 2
            local theta = 2 * math.pi * i / goldenRatio
            local phi = math.acos(1 - 2 * (i + 0.5) / numPieces)
            local baseRadius = 5 + math.sin(timeElapsed * 4 + pieceSeed * 0.1) * 2
            local radius = baseRadius * audioRadiusMult
            local spherePos = Vector3.new(math.cos(theta) * math.sin(phi) * radius, math.cos(phi) * radius, math.sin(theta) * math.sin(phi) * radius)
            finalPosition = CFrame.Angles(0, angleRad, 0) * spherePos
        elseif currentEmoteStyle == "Saturn Rings" then
            local ringIndex = (i % 3) + 1 
            local radius = (3 + ringIndex * 2.5) * audioRadiusMult
            local theta = angleRad * (1 + (ringIndex * 0.5)) + (i / numPieces) * math.pi * 2
            local ringPos = Vector3.new(math.cos(theta) * radius, math.sin(timeElapsed * 2 + ringIndex) * 0.5, math.sin(theta) * radius)
            finalPosition = CFrame.Angles(math.rad(20), 0, math.rad(-15)) * ringPos
        elseif currentEmoteStyle == "Meteor Strike" then
            local dropCycle = ((timeElapsed * 1.5) + (pieceSeed % 3)) % 3
            local startY = 25
            local endY = -3
            local currentY
            if dropCycle < 1.5 then currentY = startY - (startY - endY) * (dropCycle / 1.5)^3 
            else currentY = endY + math.random(-2, 2) * (3 - dropCycle) end
            local radius = (2 + math.noise(pieceSeed, 0, 0) * 8) * audioRadiusMult
            local theta = pieceSeed * 10 + angleRad * 0.2
            finalPosition = Vector3.new(math.cos(theta) * radius, currentY, math.sin(theta) * radius)
        elseif currentEmoteStyle == "Hyper Torus" then
            local u = (i / numPieces) * math.pi * 2 + angleRad * 0.5
            local v = pieceSeed * 0.1 + timeElapsed * 2
            local R = 7 * audioRadiusMult 
            local r = 3.5 * audioRadiusMult 
            local hX = (R + r * math.cos(v)) * math.cos(u)
            local hY = r * math.sin(v) + math.sin(timeElapsed + pieceSeed) * 2
            local hZ = (R + r * math.cos(v)) * math.sin(u)
            finalPosition = Vector3.new(hX, hY, hZ)
        end
        
        local rotRandomizer = math.random(50,200)/100
        local rotX, rotY, rotZ = math.rad(rotationAngle * rotRandomizer), math.rad(rotationAngle * rotRandomizer), math.rad(rotationAngle * rotRandomizer)

        if isMorphMode then
            local stretchX = 1 + math.abs(math.sin(timeElapsed * 3.1 + pieceSeed)) * 3
            local stretchY = 1 + math.abs(math.cos(timeElapsed * 4.2 + pieceSeed)) * 3
            local stretchZ = 1 + math.abs(math.sin(timeElapsed * 5.3 + pieceSeed)) * 3
            currentSize = currentSize * Vector3.new(stretchX, stretchY, stretchZ)
        end

        if isMeatballMode then
            local meatRadius = 1 + math.sin(timeElapsed * 5 + pieceSeed) * 0.5
            finalPosition = Vector3.new(math.sin(pieceSeed) * meatRadius, math.cos(pieceSeed * 1.5) * meatRadius, math.sin(pieceSeed * 2) * meatRadius)
            local throb = math.max(0.1, math.abs(math.sin(timeElapsed * 10 + pieceSeed)) * 3)
            currentSize = currentSize * throb
        end

        if isNoodleMode then
            local chaoticNoise = math.noise(pieceSeed, timeElapsed * 15, 0)
            local thicknessX = math.clamp(math.abs(math.sin(timeElapsed * 25 + pieceSeed) * 8) + chaoticNoise * 5, 0.01, 10)
            local thicknessY = math.clamp(math.abs(math.cos(timeElapsed * 18 + pieceSeed * 1.5) * 8) - chaoticNoise * 5, 0.01, 10)
            local length = info.realPart.Size.Magnitude * (25 + math.sin(timeElapsed * 15 + pieceSeed) * math.cos(timeElapsed * 9 + pieceSeed) * 20)
            currentSize = Vector3.new(thicknessX, thicknessY, length)
            local spiralRadius = 5 + chaoticNoise * 8
            finalPosition = finalPosition + Vector3.new(math.cos(timeElapsed * 20 + pieceSeed) * spiralRadius, math.sin(timeElapsed * 22 + pieceSeed) * spiralRadius, math.sin(timeElapsed * 14 + pieceSeed) * spiralRadius)
            rotX = rotX + math.sin(timeElapsed * 15 + pieceSeed) * 5
            rotY = rotY + math.cos(timeElapsed * 12 + pieceSeed) * 5
            rotZ = rotZ + chaoticNoise * 15
        end

        if isPaperMode then
            currentSize = Vector3.new(currentSize.X, currentSize.Y, 0.01)
            rotZ = rotZ + (timeElapsed * 50)
        end

        if isJitterMode then
            local glitchOffset = Vector3.new(math.random(-20, 20)/10, math.random(-20, 20)/10, math.random(-20, 20)/10)
            if math.random() > 0.9 then glitchOffset = glitchOffset * 5 end
            finalPosition = finalPosition + glitchOffset
        end

        if isGhostMode then
            local flicker = math.noise(timeElapsed * 30, pieceSeed, 0)
            if flicker > 0.2 then targetTransparency = 1
            elseif flicker < -0.2 then targetTransparency = 0.8 end
            info.emitter.Color = ColorSequence.new(Color3.new(0,0,0))
        end

        info.fakePart.Size = currentSize
        info.fakePart.Transparency = targetTransparency
        info.fakePart.CFrame = (rootCFrame * CFrame.new(finalPosition)) * CFrame.Angles(rotX, rotY, rotZ)
    end
end)

