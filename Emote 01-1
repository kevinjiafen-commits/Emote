local function runMainTeleport(dt)
    if not (running or closestEnabled) or not hrp then return end
    if closestEnabled then
        local enemy = getClosestHRP()
        if enemy then
            local offset = Vector3.new(0, 0, 0)
            if enemyPositionMode == "Above" then offset = Vector3.new(0, enemyTeleportDistance, 0)
            elseif enemyPositionMode == "Behind" then offset = -enemy.CFrame.LookVector * enemyTeleportDistance
            elseif enemyPositionMode == "Under" then offset = Vector3.new(0, -enemyTeleportDistance, 0)
            elseif enemyPositionMode == "InFront" then offset = enemy.CFrame.LookVector * enemyTeleportDistance
            end
            local tp = enemy.Position + offset
            if not ignoreDeathCheck and tp.Y < -20 then return end
            safeTeleport(tp)
        end
        return
    end

    if tick() - lastTeleport < teleportInterval then return end
    lastTeleport = tick()

    if teleportMode == "RANDOM" then
        local phase = tick() * 28
        local r1 = currentDistance * (0.60 + 0.40 * math.sin(phase * 2.3))
        local oX = math.cos(phase*7.1)*r1
        local oZ = math.sin(phase*7.1)*r1
        safeTeleport(hrp.Position + Vector3.new(oX, 0, oZ))
    elseif teleportMode == "FORWARD" then
        safeTeleport(hrp.Position + (hrp.CFrame.LookVector * currentDistance))
    elseif teleportMode == "CAMERA" then
        safeTeleport(hrp.Position + (camera.CFrame.LookVector * currentDistance))
    end
end

